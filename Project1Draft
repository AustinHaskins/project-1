import csv
import os
import sys
from PyQt6.QtCore import Qt
from PyQt6.QtGui import QFont
from PyQt6.QtWidgets import (
    QApplication,
    QButtonGroup,
    QFormLayout,
    QGroupBox,
    QHBoxLayout,
    QLabel,
    QLineEdit,
    QMainWindow,
    QMessageBox,
    QPushButton,
    QRadioButton,
    QStackedWidget,
    QVBoxLayout,
    QWidget,
)

CSV_FILE = "votes.csv"
CANDIDATES = ["Isabella", "Genji", "Hannah"]


def ensure_csv_exists() -> None:
    if not os.path.exists(CSV_FILE):
        with open(CSV_FILE, "w", newline="", encoding="utf-8") as file:
            writer = csv.writer(file)
            writer.writerow(["first_name", "last_name_initial", "candidate"])


def save_vote(first_name: str, last_name_initial: str, candidate: str) -> None:
    ensure_csv_exists()
    with open(CSV_FILE, "a", newline="", encoding="utf-8") as file:
        writer = csv.writer(file)
        writer.writerow([first_name, last_name_initial, candidate])


def get_vote_totals() -> dict:
    ensure_csv_exists()
    totals = {candidate: 0 for candidate in CANDIDATES}

    with open(CSV_FILE, "r", newline="", encoding="utf-8") as file:
        reader = csv.DictReader(file)
        for row in reader:
            candidate = row.get("candidate", "").strip()
            if candidate in totals:
                totals[candidate] += 1

    return totals


class VoterInfoPage(QWidget):
    def __init__(self, parent_window):
        super().__init__()
        self.parent_window = parent_window
        self.setup_ui()

    def setup_ui(self):
        main_layout = QVBoxLayout()
        main_layout.setContentsMargins(40, 40, 40, 40)
        main_layout.setSpacing(25)
        main_layout.setAlignment(Qt.AlignmentFlag.AlignTop)

        title = QLabel("Candidate Voting Verification")
        title_font = QFont()
        title_font.setPointSize(16)
        title_font.setBold(True)
        title.setFont(title_font)
        title.setAlignment(Qt.AlignmentFlag.AlignCenter)

        form_box = QGroupBox()
        form_layout = QFormLayout()
        form_layout.setSpacing(15)

        self.first_name_input = QLineEdit()
        self.first_name_input.setPlaceholderText("Enter first name")

        self.last_name_input = QLineEdit()
        self.last_name_input.setPlaceholderText("Enter last name or initial")

        form_layout.addRow("First Name:", self.first_name_input)
        form_layout.addRow("Last Name/Initial:", self.last_name_input)
        form_box.setLayout(form_layout)

        button_row = QHBoxLayout()
        self.next_button = QPushButton("Next")
        self.next_button.setFixedWidth(120)
        self.next_button.clicked.connect(self.go_to_candidate_page)
        button_row.addStretch()
        button_row.addWidget(self.next_button)
        button_row.addStretch()

        main_layout.addWidget(title)
        main_layout.addSpacing(10)
        main_layout.addWidget(form_box)
        main_layout.addStretch()
        main_layout.addLayout(button_row)

        self.setLayout(main_layout)

    def go_to_candidate_page(self):
        first_name = self.first_name_input.text().strip()
        last_name = self.last_name_input.text().strip()

        if not first_name or not last_name:
            QMessageBox.warning(self, "Missing Information", "Please enter both first name and last name/initial.")
            return

        self.parent_window.first_name = first_name
        self.parent_window.last_name = last_name
        self.parent_window.stacked_widget.setCurrentIndex(1)


class CandidatePage(QWidget):
    def __init__(self, parent_window):
        super().__init__()
        self.parent_window = parent_window
        self.setup_ui()

    def setup_ui(self):
        main_layout = QVBoxLayout()
        main_layout.setContentsMargins(40, 40, 40, 40)
        main_layout.setSpacing(25)
        main_layout.setAlignment(Qt.AlignmentFlag.AlignTop)

        title = QLabel("Vote for Candidate")
        title_font = QFont()
        title_font.setPointSize(16)
        title_font.setBold(True)
        title.setFont(title_font)
        title.setAlignment(Qt.AlignmentFlag.AlignCenter)

        candidate_box = QGroupBox("Candidates")
        candidate_layout = QVBoxLayout()
        candidate_layout.setSpacing(12)

        self.button_group = QButtonGroup(self)
        self.radio_isabella = QRadioButton("Isabella")
        self.radio_genji = QRadioButton("Genji")
        self.radio_hannah = QRadioButton("Hannah")

        self.button_group.addButton(self.radio_isabella)
        self.button_group.addButton(self.radio_genji)
        self.button_group.addButton(self.radio_hannah)

        candidate_layout.addWidget(self.radio_isabella)
        candidate_layout.addWidget(self.radio_genji)
        candidate_layout.addWidget(self.radio_hannah)
        candidate_box.setLayout(candidate_layout)

        button_row = QHBoxLayout()
        self.submit_button = QPushButton("Submit")
        self.submit_button.setFixedWidth(120)
        self.submit_button.clicked.connect(self.submit_vote)
        button_row.addStretch()
        button_row.addWidget(self.submit_button)
        button_row.addStretch()

        main_layout.addWidget(title)
        main_layout.addSpacing(10)
        main_layout.addWidget(candidate_box)
        main_layout.addStretch()
        main_layout.addLayout(button_row)

        self.setLayout(main_layout)

    def submit_vote(self):
        selected_button = self.button_group.checkedButton()

        if selected_button is None:
            QMessageBox.warning(self, "No Candidate Selected", "Please choose a candidate before submitting.")
            return

        selected_candidate = selected_button.text()
        self.parent_window.selected_candidate = selected_candidate

        save_vote(
            self.parent_window.first_name,
            self.parent_window.last_name,
            selected_candidate,
        )

        self.parent_window.results_page.update_results(selected_candidate)
        self.parent_window.stacked_widget.setCurrentIndex(2)


class ResultsPage(QWidget):
    def __init__(self, parent_window):
        super().__init__()
        self.parent_window = parent_window
        self.setup_ui()

    def setup_ui(self):
        main_layout = QVBoxLayout()
        main_layout.setContentsMargins(40, 40, 40, 40)
        main_layout.setSpacing(20)
        main_layout.setAlignment(Qt.AlignmentFlag.AlignTop)

        title = QLabel("Thank you for voting")
        title_font = QFont()
        title_font.setPointSize(16)
        title_font.setBold(True)
        title.setFont(title_font)
        title.setAlignment(Qt.AlignmentFlag.AlignCenter)

        self.vote_label = QLabel("You voted for ")
        self.vote_label.setAlignment(Qt.AlignmentFlag.AlignCenter)

        totals_title = QLabel("Current Vote Totals")
        totals_title_font = QFont()
        totals_title_font.setBold(True)
        totals_title.setFont(totals_title_font)
        totals_title.setAlignment(Qt.AlignmentFlag.AlignCenter)

        self.isabella_total = QLabel("Isabella: 0")
        self.genji_total = QLabel("Genji: 0")
        self.hannah_total = QLabel("Hannah: 0")

        for label in [self.isabella_total, self.genji_total, self.hannah_total]:
            label.setAlignment(Qt.AlignmentFlag.AlignCenter)

        self.new_vote_button = QPushButton("New Vote")
        self.new_vote_button.setFixedWidth(140)
        self.new_vote_button.clicked.connect(self.start_new_vote)

        button_row = QHBoxLayout()
        button_row.addStretch()
        button_row.addWidget(self.new_vote_button)
        button_row.addStretch()

        main_layout.addWidget(title)
        main_layout.addWidget(self.vote_label)
        main_layout.addSpacing(15)
        main_layout.addWidget(totals_title)
        main_layout.addWidget(self.isabella_total)
        main_layout.addWidget(self.genji_total)
        main_layout.addWidget(self.hannah_total)
        main_layout.addStretch()
        main_layout.addLayout(button_row)

        self.setLayout(main_layout)

    def update_results(self, selected_candidate: str):
        totals = get_vote_totals()
        self.vote_label.setText(f"You voted for {selected_candidate}")
        self.isabella_total.setText(f"Isabella: {totals['Isabella']}")
        self.genji_total.setText(f"Genji: {totals['Genji']}")
        self.hannah_total.setText(f"Hannah: {totals['Hannah']}")

    def start_new_vote(self):
        self.parent_window.voter_info_page.first_name_input.clear()
        self.parent_window.voter_info_page.last_name_input.clear()
        self.parent_window.candidate_page.button_group.setExclusive(False)
        self.parent_window.candidate_page.radio_isabella.setChecked(False)
        self.parent_window.candidate_page.radio_genji.setChecked(False)
        self.parent_window.candidate_page.radio_hannah.setChecked(False)
        self.parent_window.candidate_page.button_group.setExclusive(True)
        self.parent_window.stacked_widget.setCurrentIndex(0)


class VotingApp(QMainWindow):
    def __init__(self):
        super().__init__()
        self.first_name = ""
        self.last_name = ""
        self.selected_candidate = ""
        self.setWindowTitle("Voting Menu")
        self.setMinimumSize(500, 350)
        self.setup_ui()
        self.apply_styles()

    def setup_ui(self):
        self.stacked_widget = QStackedWidget()

        self.voter_info_page = VoterInfoPage(self)
        self.candidate_page = CandidatePage(self)
        self.results_page = ResultsPage(self)

        self.stacked_widget.addWidget(self.voter_info_page)
        self.stacked_widget.addWidget(self.candidate_page)
        self.stacked_widget.addWidget(self.results_page)

        self.setCentralWidget(self.stacked_widget)

