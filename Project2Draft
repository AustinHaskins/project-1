import json
import sys
from pathlib import Path
from PyQt6.QtCore import QPoint, Qt
from PyQt6.QtGui import QFont
from PyQt6.QtWidgets import (
    QApplication,
    QButtonGroup,
    QComboBox,
    QFrame,
    QGridLayout,
    QGroupBox,
    QHBoxLayout,
    QLabel,
    QMainWindow,
    QPushButton,
    QRadioButton,
    QSlider,
    QStyle,
    QStyleOptionSlider,
    QToolTip,
    QVBoxLayout,
    QWidget,
)

DATA_FILE = Path(__file__).resolve().parent.parent / "vacation_spots_complete_partial.json"
SLIDER_MIN = 169
SLIDER_MAX = 938


def load_database(path: Path):
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def collect_options(data):
    seasons = ["spring", "summer", "fall", "winter"]
    activities = set()

    for spot in data:
        primary = spot.get("primary_activity")
        if primary:
            activities.add(primary)
        for tag in spot.get("secondary_tags", []):
            if tag:
                activities.add(tag)

    return {
        "seasons": seasons,
        "activities": sorted(activities),
    }


class VacationInputPage(QMainWindow):
    def __init__(self, config):
        super().__init__()
        self.config = config
        self.setWindowTitle("Vacation Spot Finder - Input Draft")
        self.setMinimumSize(920, 680)
        self.build_ui()

    def build_ui(self):
        root = QWidget()
        self.setCentralWidget(root)

        outer = QVBoxLayout(root)
        outer.setContentsMargins(24, 16, 24, 16)
        outer.setSpacing(12)

        title = QLabel("Vacation Spot Finder")
        title_font = QFont()
        title_font.setPointSize(20)
        title_font.setBold(True)
        title.setFont(title_font)

        subtitle = QLabel(
            "Please fill out the inputs so we can find the best match for your trip."
        )
        subtitle.setWordWrap(True)
        subtitle.setStyleSheet("color: #5b6675; font-size: 15px;")

        outer.addWidget(title)
        outer.addWidget(subtitle)

        card = QFrame()
        card.setObjectName("card")
        form_layout = QGridLayout(card)
        form_layout.setContentsMargins(26, 24, 26, 24)
        form_layout.setHorizontalSpacing(22)
        form_layout.setVerticalSpacing(16)

        self.season_combo = QComboBox()
        self.season_combo.addItems([s.title() for s in self.config["seasons"]])

        self.primary_combo = QComboBox()
        self.primary_combo.addItems([self.pretty_label(a) for a in self.config["activities"]])

        self.secondary_combo = QComboBox()
        self.secondary_combo.addItem("No preference")
        self.secondary_combo.addItems([self.pretty_label(a) for a in self.config["activities"]])

        form_layout.addWidget(QLabel("Trip season"), 0, 0)
        form_layout.addWidget(self.season_combo, 0, 1)
        form_layout.addWidget(QLabel("Primary activity"), 1, 0)
        form_layout.addWidget(self.primary_combo, 1, 1)
        form_layout.addWidget(QLabel("Secondary activity"), 2, 0)
        form_layout.addWidget(self.secondary_combo, 2, 1)

        self.region_group = QButtonGroup(self)
        self.us_radio = QRadioButton("U.S.")
        self.intl_radio = QRadioButton("International")
        self.us_radio.setChecked(True)
        self.region_group.addButton(self.us_radio, 0)
        self.region_group.addButton(self.intl_radio, 1)

        region_group_box = QGroupBox("Trip region")
        region_group_box.setObjectName("pillGroup")
        region_layout = QHBoxLayout(region_group_box)
        region_layout.setContentsMargins(18, 18, 18, 14)
        region_layout.setSpacing(24)
        region_layout.addWidget(self.us_radio)
        region_layout.addWidget(self.intl_radio)
        region_layout.addStretch()
        form_layout.addWidget(region_group_box, 3, 0, 1, 2)

        temp_group_box = QGroupBox("Preferred average temperature")
        temp_group_box.setObjectName("pillGroup")
        temp_layout = QVBoxLayout(temp_group_box)
        temp_layout.setContentsMargins(18, 0, 18, 16)
        temp_layout.setSpacing(20)

        self.temp_value = QLabel()
        self.temp_value.setObjectName("tempValue")

        self.temp_slider = QSlider(Qt.Orientation.Horizontal)
        self.temp_slider.setMinimum(SLIDER_MIN)
        self.temp_slider.setMaximum(SLIDER_MAX)
        self.temp_slider.setValue((SLIDER_MIN + SLIDER_MAX) // 2)
        self.temp_slider.setTickPosition(QSlider.TickPosition.NoTicks)
        self.temp_slider.valueChanged.connect(self.update_temp_label)
        self.temp_slider.sliderMoved.connect(self.show_slider_tooltip)
        self.temp_slider.sliderPressed.connect(self.show_current_slider_tooltip)

        range_row = QHBoxLayout()
        range_row.setContentsMargins(0, 0, 0, 0)
        range_row.addWidget(QLabel("16.9°F"))
        range_row.addStretch()
        range_row.addWidget(QLabel("93.8°F"))

        temp_layout.addWidget(self.temp_value)
        temp_layout.addWidget(self.temp_slider)
        temp_layout.addLayout(range_row)
        form_layout.addWidget(temp_group_box, 4, 0, 1, 2)

        button_row = QHBoxLayout()
        button_row.addStretch()
        self.continue_button = QPushButton("Find a Location!")
        self.continue_button.clicked.connect(self.show_placeholder)
        button_row.addWidget(self.continue_button)
        form_layout.addLayout(button_row, 5, 0, 1, 2)

        outer.addWidget(card)

        self.preview_label = QLabel(
            ""
        )
        self.preview_label.setWordWrap(True)
        self.preview_label.setObjectName("preview")
        outer.addWidget(self.preview_label)
        outer.addStretch()

        self.update_temp_label(self.temp_slider.value())
        self.apply_styles()

    def pretty_label(self, raw: str) -> str:
        return raw.replace("_", " ").title()

    def selected_region(self) -> str:
        return "U.S." if self.us_radio.isChecked() else "International"

    def slider_temp(self) -> float:
        return self.temp_slider.value() / 10.0

    def update_temp_label(self, value: int):
        self.temp_value.setText(f"{value / 10.0:.1f}°F")
        if self.temp_slider.isSliderDown():
            self.show_slider_tooltip(value)

    def show_current_slider_tooltip(self):
        self.show_slider_tooltip(self.temp_slider.value())

    def show_slider_tooltip(self, value: int):
        option = QStyleOptionSlider()
        self.temp_slider.initStyleOption(option)
        handle_rect = self.temp_slider.style().subControlRect(
            QStyle.ComplexControl.CC_Slider,
            option,
            QStyle.SubControl.SC_SliderHandle,
            self.temp_slider,
        )
        center = handle_rect.center()
        global_pos = self.temp_slider.mapToGlobal(QPoint(center.x(), handle_rect.top() - 18))
        QToolTip.showText(global_pos, f"{value / 10.0:.1f}°F", self.temp_slider, handle_rect)

    def show_placeholder(self):
        season = self.season_combo.currentText()
        primary = self.primary_combo.currentText()
        secondary = self.secondary_combo.currentText()
        region = self.selected_region()
        temp = self.slider_temp()
        self.preview_label.setText(
            f"Selected inputs: season={season}, primary={primary}, secondary={secondary}, region={region}, preferred temp={temp:.1f}°F. "
            "To be updated to show location output"
        )

    def apply_styles(self):
        self.setStyleSheet(
            """
            QWidget {
                background: #f3f4f6;
                color: #1f2937;
                font-size: 14px;
            }
            QLabel {
                background: transparent;
            }
            QFrame#card, QLabel#preview {
                background: white;
                border: 1px solid #d4dae3;
                border-radius: 16px;
            }
            QFrame#card {
                border-radius: 18px;
            }
            QGroupBox#pillGroup {
                background: #f7f7f8;
                border: 1px solid #cfd5dd;
                border-radius: 18px;
                margin-top: 10px;
                padding-top: 10px;
                font-weight: 600;
                color: #1f2937;
            }
            QGroupBox#pillGroup::title {
                subcontrol-origin: margin;
                left: 14px;
                padding: 0 8px;
                background: #f3f4f6;
            }
            QComboBox, QPushButton {
                min-height: 40px;
                border-radius: 10px;
                border: 1px solid #c7d2de;
                padding: 6px 10px;
                background: white;
            }
            QComboBox:hover, QPushButton:hover {
                border-color: #7aa7d9;
            }
            QPushButton {
                background: #246bce;
                color: white;
                font-weight: 600;
                min-width: 120px;
            }
            QPushButton:hover {
                background: #1e5fb8;
            }
            QLabel#preview {
                padding: 16px;
                color: #334e68;
            }
            QLabel#tempValue {
                font-size: 17px;
                font-weight: 700;
                color: #243b53;
            }
            QRadioButton {
                spacing: 8px;
                color: #243b53;
                background: transparent;
            }
            QRadioButton::indicator {
            width: 18px;
            height: 18px;
            }
            QRadioButton::indicator:unchecked {
            border: 2px solid #9aa5b1;
            border-radius: 9px;
            background: white;
            }
            QRadioButton::indicator:checked {
            border: 2px solid #246bce;
            border-radius: 9px;
            background: #246bce;
            }
            QSlider {
                background: transparent;
                min-height: 26px;
            }
            QSlider::groove:horizontal {
                border: none;
                height: 8px;
                background: #d6dbe3;
                border-radius: 3px;
            }
            QSlider::sub-page:horizontal {
                background: #246bce;
                border-radius: 4px;
            }
            QSlider::add-page:horizontal {
                background: #d6dbe3;
                border-radius: 4px;
            }
            QSlider::handle:horizontal {
                background: white;
                border: 2px solid #246bce;
                width: 20px;
                height: 20px;
                margin: -7px 0;
                border-radius: 10px;
            }
            QToolTip {
                background: #1f2937;
                color: white;
                border: 1px solid #111827;
                padding: 6px 10px;
                border-radius: 8px;
                font-size: 12px;
            }
            """
        )


if __name__ == "__main__":
    data = load_database(DATA_FILE)
    config = collect_options(data)
    app = QApplication(sys.argv)
    window = VacationInputPage(config)
    window.show()
    sys.exit(app.exec())
